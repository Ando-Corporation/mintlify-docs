{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ando",
  "colors": {
    "primary": "#09090B",
    "light": "#D4D4D8",
    "dark": "#71717A"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "api": {
    "openapi": "openapi-public-api-v1-2026-05-17.json",
    "url": "full",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "defaults": "required",
      "languages": [
        "bash",
        "javascript",
        "python"
      ]
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "docs/start-guide",
              "docs/concepts",
              "docs/download-ando"
            ]
          },
          {
            "group": "Your Sidebar",
            "pages": [
              "docs/inbox",
              "docs/search",
              "docs/messages"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "docs/ando-mcp",
              "docs/import-data-from-other-apps",
              "docs/importing-from-slack"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "icon": "history",
        "groups": [
          {
            "group": "Updates",
            "pages": [
              "changelog",
              "coming-soon"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "icon": "braces",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "api-reference/overview",
              "api-reference/authorization"
            ]
          },
          {
            "group": "Stable workflows",
            "pages": [
              "api-reference/messaging-quickstart",
              "api-reference/search-quickstart",
              "api-reference/http-api"
            ]
          },
          {
            "group": "Endpoint reference",
            "pages": [
              "api-reference/endpoint-reference",
              {
                "group": "Stable search",
                "tag": "Stable",
                "openapi": "openapi-public-api-v1-2026-05-17.json",
                "pages": [
                  "GET /search/messages",
                  "GET /search/conversations",
                  "GET /search/members",
                  "GET /search/calls"
                ]
              },
              {
                "group": "Stable messaging",
                "tag": "Stable",
                "openapi": "openapi-public-api-v1-2026-05-17.json",
                "pages": [
                  "GET /conversations/{conversationId}/messages",
                  "POST /conversations/{conversationId}/messages",
                  "GET /conversation-messages/{messageId}",
                  "GET /conversation-messages/{messageId}/replies"
                ]
              },
              {
                "group": "Nearly stable",
                "tag": "Candidate",
                "openapi": "openapi-public-api-v1-2026-05-17.json",
                "pages": [
                  "GET /search/tasks"
                ]
              },
              {
                "group": "Preview",
                "tag": "Preview",
                "openapi": "openapi-public-api-v1-2026-05-17.json",
                "pages": [
                  "GET /members/{memberId}",
                  "GET /calls/{callId}",
                  "GET /calls/{callId}/transcript",
                  "GET /tasks/{taskId}",
                  "POST /tasks/{taskId}/updates"
                ]
              },
              {
                "group": "Legacy compatibility",
                "tag": "Legacy",
                "openapi": "openapi-public-api-v1-2026-05-17.json",
                "pages": [
                  "GET /search/clipboard",
                  "GET /clipboards/{clipboardId}"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Ando",
          "href": "https://ando.so",
          "icon": "external-link"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@ando.so"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Ando",
      "href": "https://app.ando.so"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/andocorporation",
      "linkedin": "https://linkedin.com/company/andohq"
    }
  },
  "redirects": [
    {
      "source": "/docs",
      "destination": "/docs/start-guide"
    },
    {
      "source": "/docs/api",
      "destination": "/api-reference/overview"
    },
    {
      "source": "/api-reference",
      "destination": "/api-reference/overview"
    },
    {
      "source": "/api-reference/openapi.json",
      "destination": "/openapi-public-api-v1-2026-05-17.json"
    },
    {
      "source": "/openapi.json",
      "destination": "/openapi-public-api-v1-2026-05-17.json"
    }
  ]
}
