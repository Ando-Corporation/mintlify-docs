{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ando",
  "colors": {
    "primary": "#09090B",
    "light": "#D4D4D8",
    "dark": "#71717A"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "docs/start-guide",
              "docs/concepts",
              "docs/download-ando"
            ]
          },
          {
            "group": "Your Sidebar",
            "pages": [
              "docs/inbox",
              "docs/search",
              "docs/messages"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "docs/ando-mcp",
              "docs/importing-from-slack"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "icon": "history",
        "groups": [
          {
            "group": "Updates",
            "pages": [
              "changelog",
              "coming-soon"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "icon": "braces",
        "groups": [
          {
            "group": "HTTP API",
            "pages": [
              "api-reference/http-api"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Ando",
          "href": "https://ando.so",
          "icon": "external-link"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@ando.so"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Ando",
      "href": "https://app.ando.so"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/andocorporation",
      "linkedin": "https://linkedin.com/company/andohq"
    }
  },
  "redirects": [
    {
      "source": "/docs",
      "destination": "/docs/start-guide"
    },
    {
      "source": "/docs/api",
      "destination": "/api-reference/http-api"
    }
  ]
}
